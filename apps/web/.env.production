# Production build configuration — auto-loaded by Vite during npm run build
# When the React SPA and API are served from the same Azure App Service,
# use a relative URL so the browser calls the same host it was served from.
VITE_API_BASE_URL=/api/v1
VITE_ENABLE_AI_INSIGHTS=true
VITE_ENABLE_QUERY_DEVTOOLS=false
VITE_ENABLE_PERFORMANCE_MONITORING=false
