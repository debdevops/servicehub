# ServiceHub Web Frontend Environment Variables
# ==============================================
# Copy this file to .env.local and fill in the values for your environment.
#
# Vite uses VITE_ prefix for client-exposed environment variables.
# Variables without VITE_ prefix are only available server-side.

# API Configuration
# -----------------
# URL of the ServiceHub API backend.
#
# LOCAL DEVELOPMENT (default — no change needed):
# The Vite proxy in vite.config.ts automatically forwards /api requests
# to http://localhost:5153. You do not need to set this variable.
#
# REMOTE SERVER ACCESS:
# If you need to override the API URL (e.g., pointing to a different server),
# uncomment and set this variable:
# VITE_API_BASE_URL=http://your-server-hostname:5153/api/v1
#

# Application Insights
# --------------------
# Connection string from Azure Portal > Application Insights > Overview > Connection String.
# Leave empty to disable telemetry collection.
# VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
#
# Sampling percentage (1-100). Lower = less telemetry = lower cost.
# Default: 50 (sends 50% of telemetry events)
# VITE_APPINSIGHTS_SAMPLING_PERCENTAGE=50
# PRODUCTION / AZURE DEPLOYMENT:
# Set this to a relative path when API and UI are served from the same host:
# VITE_API_BASE_URL=/api/v1
# VITE_API_BASE_URL=http://localhost:5153/api/v1

# Feature Flags
# -------------
# Enable/disable AI insights feature
VITE_ENABLE_AI_INSIGHTS=true

# Enable/disable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# Development Settings
# --------------------
# Enable React Query devtools in development
VITE_ENABLE_QUERY_DEVTOOLS=true

# Production Settings (uncomment for production builds)
# -----------------------------------------------------
# VITE_API_BASE_URL=https://your-api-domain.com/api/v1
# VITE_ENABLE_QUERY_DEVTOOLS=false
# VITE_ENABLE_PERFORMANCE_MONITORING=true

# Production overrides (auto-loaded by Vite when NODE_ENV=production)
# Create .env.production with this content for Azure deployment:
# VITE_API_BASE_URL=/api/v1
