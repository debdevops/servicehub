{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "ServiceHub": "Information"
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "SET_VIA_ENV_VAR",
    "EnableAdaptiveSampling": true,
    "SamplingPercentage": 33,
    "MaxTelemetryItemsPerSecond": 5
  },

  "AllowedHosts": "app-servicehub-prod.azurewebsites.net",

  "SiteUrl": "https://app-servicehub-prod.azurewebsites.net",

  "Cors": {
    "AllowedOrigins": [
      "https://app-servicehub-prod.azurewebsites.net"
    ]
  },

  "Security": {
    "EncryptionKey": "SET_VIA_ENV_VAR",
    "EnableConnectionStringEncryption": true,
    "SpaToken": {
      "Enabled": true,
      "Secret": "SET_VIA_ENV_VAR"
    },
    "Authentication": {
      "Enabled": true,
      "ApiKeys": [],
      "ScopedApiKeys": [
        {
          "Key": "SET_VIA_ENV_VAR_Security__Authentication__ScopedApiKeys__0__Key",
          "Scopes": [],
          "Description": "Admin key (all scopes) — set via Azure App Service env var"
        },
        {
          "Key": "SET_VIA_ENV_VAR_Security__Authentication__ScopedApiKeys__1__Key",
          "Scopes": [
            "namespaces:read",
            "queues:read",
            "topics:read",
            "subscriptions:read",
            "messages:peek",
            "dlq:read",
            "anomalies:read"
          ],
          "Description": "Read-only key — set via Azure App Service env var"
        }
      ]
    },
    "EasyAuth": {
      "Enabled": true,
      "Description": "Azure App Service Easy Authentication via Microsoft identity provider"
    },
    "Headers": {
      "Enabled": true
    }
  },

  "SecurityHeaders": {
    "Enabled": true,
    "ContentTypeOptions": "nosniff",
    "FrameOptions": "DENY",
    "ReferrerPolicy": "strict-origin-when-cross-origin",
    "XssProtection": "1; mode=block",
    "ContentSecurityPolicyProduction": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'",
    "PermissionsPolicy": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()",
    "StrictTransportSecurity": "max-age=31536000; includeSubDomains; preload"
  },

  "ServiceBus": {
    "ConnectionCacheExpirationMinutes": 60,
    "MaxConcurrentCalls": 10,
    "PrefetchCount": 100,
    "DefaultTimeout": "00:00:30",
    "RetryCount": 3,
    "RetryDelayMs": 1000,
    "MaxRetryDelayMs": 30000
  },

  "AI": {
    "Enabled": false
  },

  "RateLimit": {
    "PermitLimit": 60,
    "Window": "00:01:00"
  },

  "HealthChecks": {
    "Enabled": true,
    "CacheDurationSeconds": 60
  },

  "Swagger": {
    "Enabled": false
  },

  "DlqDatabase": {
    "DataDirectory": "/home/data"
  },

  "NamespaceRepository": {
    "DataDirectory": "/home/data"
  }
}
