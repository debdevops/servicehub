{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "ServiceHub": "Information"
    }
  },
  
  "AllowedHosts": "*",

  "Cors": {
    "AllowedOrigins": [
      "https://servicehub.azurewebsites.net"
    ]
  },

  "Security": {
    "EncryptionKey": "SET_VIA_KEYVAULT_OR_ENV_VAR",
    "EnableConnectionStringEncryption": true,
    "Authentication": {
      "Enabled": true,
      "ApiKeys": [],
      "ScopedApiKeys": [
        {
          "Key": "REPLACED_BY_KEYVAULT_servicehub_api_key_admin",
          "Scopes": [],
          "Description": "Admin key (all scopes) — value loaded from Key Vault"
        },
        {
          "Key": "REPLACED_BY_KEYVAULT_servicehub_api_key_readonly",
          "Scopes": [
            "namespaces:read",
            "queues:read",
            "topics:read",
            "subscriptions:read",
            "messages:peek",
            "dlq:read",
            "anomalies:read"
          ],
          "Description": "Read-only key — value loaded from Key Vault"
        }
      ]
    },
    "Headers": {
      "Enabled": true
    }
  },

  "SecurityHeaders": {
    "Enabled": true,
    "ContentTypeOptions": "nosniff",
    "FrameOptions": "DENY",
    "ReferrerPolicy": "strict-origin-when-cross-origin",
    "XssProtection": "1; mode=block",
    "ContentSecurityPolicyProduction": "default-src 'none'; frame-ancestors 'none'",
    "PermissionsPolicy": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()",
    "StrictTransportSecurity": "max-age=31536000; includeSubDomains; preload"
  },

  "ServiceBus": {
    "ConnectionCacheExpirationMinutes": 60,
    "MaxConcurrentCalls": 10,
    "PrefetchCount": 100,
    "DefaultTimeout": "00:00:30",
    "RetryCount": 3,
    "RetryDelayMs": 1000,
    "MaxRetryDelayMs": 30000
  },

  "AI": {
    "Enabled": false
  },

  "RateLimit": {
    "PermitLimit": 60,
    "Window": "00:01:00"
  },

  "HealthChecks": {
    "Enabled": true,
    "CacheDurationSeconds": 60
  },

  "Swagger": {
    "Enabled": false
  },

  "KeyVault": {
    "VaultUri": "https://your-vault-name.vault.azure.net/"
  },

  "DlqDatabase": {
    "DataDirectory": "/home/data"
  },

  "NamespaceRepository": {
    "DataDirectory": "/home/data"
  }
}
