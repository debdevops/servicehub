{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ServiceHub": "Information",
      "ServiceHub.Simulator": "Debug"
    }
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5173"
    ],
    "DevelopmentAllowAnyOrigin": true
  },

  "Security": {
    "EncryptionKey": "SIMULATOR_KEY_NOT_FOR_PRODUCTION_1234567890_1234",
    "EnableConnectionStringEncryption": false,
    "SpaToken": {
      "Enabled": false
    },
    "Authentication": {
      "Enabled": false,
      "ApiKeys": [],
      "ScopedApiKeys": []
    }
  },

  "AI": {
    "Enabled": false
  },

  "Swagger": {
    "Enabled": true
  },

  "RateLimit": {
    "MaxRequests": 9999,
    "WindowDuration": "00:01:00"
  },

  "CloudProviders": {
    "Aws": {
      "Enabled": true
    },
    "Gcp": {
      "Enabled": true
    }
  },

  "Simulator": {
    "Enabled": true,
    "AutoSeedOnStartup": true
  }
}
