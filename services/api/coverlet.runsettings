<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>

          <!-- Only measure production assemblies — exclude test projects -->
          <Include>
            [ServiceHub.Api]*,
            [ServiceHub.Core]*,
            [ServiceHub.Infrastructure]*,
            [ServiceHub.Shared]*,
            [ServiceHub.Simulator]*
          </Include>

          <!-- Exclude generated code and boilerplate -->
          <Exclude>
            [ServiceHub.UnitTests]*,
            [ServiceHub.IntegrationTests]*,
            [*]System.Text.RegularExpressions.*,
            [*]Microsoft.AspNetCore.OpenApi.*
          </Exclude>

          <ExcludeByFile>
            **/*.g.cs,
            **/*.generated.cs,
            **/Migrations/**,
            **/wwwroot/**
          </ExcludeByFile>

          <!-- Skip auto-property getters/setters — no testable logic -->
          <SkipAutoProps>true</SkipAutoProps>

          <!-- ─────────────────────────────────────────────────────── -->
          <!-- Code Coverage Thresholds                                -->
          <!-- BUILD WILL FAIL if coverage falls below these minimums  -->
          <!-- ─────────────────────────────────────────────────────── -->
          <Threshold>
            <Metric>Line</Metric>
            <Acceptable>60</Acceptable>
            <Warning>70</Warning>
          </Threshold>
          <Threshold>
            <Metric>Branch</Metric>
            <Acceptable>50</Acceptable>
            <Warning>65</Warning>
          </Threshold>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
